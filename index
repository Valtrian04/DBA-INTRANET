        .redacted-box { background-color: #000; height: 35px; width: 100%; }

        #tab-prueba { display: none; padding: 25px; }
        .form-section { background-color: #d4d0c8; border: 2px inset #ffffff; padding: 15px; margin-bottom: 20px; }
        .form-question { font-weight: bold; margin-bottom: 10px; color: #000066; }
