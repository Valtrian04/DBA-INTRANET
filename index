        .doc-table th { background-color: #c0c0c0; border: 1px solid #808080; padding: 8px; text-align: left; border-bottom: 2px solid #808080; }
        .doc-table td { border: 1px solid #808080; padding: 8px; background-color: #e5e1d3; }
