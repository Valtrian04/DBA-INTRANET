        #navbar { background-color: #d4d0c8; border-bottom: 2px solid #808080; display: flex; padding: 5px; }
        .nav-btn { background-color: #d4d0c8; border: 2px outset #ffffff; padding: 8px 5px; margin-right: 5px; font-family: "Courier New", Courier, monospace; font-size: 14px; color: #000080; text-decoration: none; cursor: pointer; text-align: center; flex: 1; display: flex; justify-content: center; align-items: center; }
