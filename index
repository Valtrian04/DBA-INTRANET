        .contacto-text { font-size: 16px; margin-bottom: 20px; font-weight: bold; }
        .contacto-number-blue { font-size: 36px; color: #000080; font-weight: bold; margin-bottom: 40px; letter-spacing: 2px;}
        .contacto-number-black { font-size: 36px; color: #000000; font-weight: bold; letter-spacing: 2px;}

        #tab-faq { display: none; padding: 40px 60px; }
