        #chat-send-btn { background-color: #d4d0c8; border: 2px outset #ffffff; cursor: pointer; font-family: Tahoma, Arial, sans-serif; font-size: 12px; padding: 0 10px; }

        /* --- PANTALLA DE LOGIN BIOMÉTRICO (RÚSTICA Y GLITCH) --- */
        #login-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background-color: #051005; color: #00ff00;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            z-index: 9999; font-family: "Courier New", Courier, monospace; text-align: center;
        }
        .login-title { font-size: 24px; font-weight: bold; margin-bottom: 20px; letter-spacing: 2px; text-shadow: 0 0 5px #00ff00; }
        #scanner-container {
            width: 320px; height: 240px; border: 3px ridge #004400; position: relative;
            background: #000; overflow: hidden; margin-bottom: 20px; box-shadow: 0 0 25px rgba(0,255,0,0.3);
        }
        #cam-feed { 
            width: 320px; height: 240px; object-fit: cover; 
            /* Efecto monitor defectuoso muy pronunciado */
            filter: grayscale(100%) contrast(200%) sepia(100%) hue-rotate(80deg) blur(0.5px);
            transform: scaleX(-1); /* Efecto espejo */
        }
        
        #face-box {
            position: absolute; border: 2px solid #ff0000; box-shadow: 0 0 8px #ff0000;
            display: none; z-index: 15; background: rgba(255, 0, 0, 0.1);
        }

        /* EFECTO DE FLASH DE CÁMARA */
        #flash-effect {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background-color: #ffffff; z-index: 99; opacity: 0; pointer-events: none;
        }
        .trigger-flash {
            animation: flashAnimation 0.8s ease-out forwards;
        }
        @keyframes flashAnimation {
            0% { opacity: 1; }
            100% { opacity: 0; }
        }

        #scan-line {
            position: absolute; top: 0; left: 0; width: 100%; height: 4px;
            background: rgba(0, 255, 0, 0.6); box-shadow: 0 0 15px #00ff00;
            display: none; animation: scanAnim 1.5s linear infinite; z-index: 20;
        }
        @keyframes scanAnim { 0% { top: -10%; } 100% { top: 110%; } }
        
        #terminal-output {
            width: 450px; height: 140px; border: 2px groove #004400; background: #020a02;
            padding: 10px; overflow-y: hidden; font-size: 13px;
            text-align: left; display: flex; flex-direction: column; justify-content: flex-end;
            margin-bottom: 20px; text-shadow: 0 0 3px #00ff00;
        }
        .login-btn {
            background-color: #003300; color: #00ff00; border: 2px outset #00ff00;
            padding: 10px 20px; font-family: "Courier New", Courier, monospace; font-size: 16px;
            font-weight: bold; cursor: pointer; transition: 0.2s;
        }
        .login-btn:active { border: 2px inset #00ff00; background-color: #002200; }
        .login-btn:disabled { color: #004400; border-color: #004400; cursor: not-allowed; text-shadow: none; }

        /* --- PANTALLA DE TRANSICIÓN --- */
        #transition-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background-color: #051005; color: #00ff00;
            display: none; flex-direction: column; align-items: center; justify-content: center;
            z-index: 10000; font-family: "Courier New", Courier, monospace;
            text-shadow: 0 0 10px #00ff00; letter-spacing: 4px; font-size: 28px; font-weight: bold;
        }
        .blink-text { animation: blink 1s step-end infinite; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

        .glitch-text-green {
            animation: textGlitchGreen 2s infinite;
            font-size: 32px; font-weight: bold; position: relative; z-index: 60;
        }
        @keyframes textGlitchGreen {
            0%, 100% { text-shadow: 2px 0 #00ff00, -2px 0 #005500; transform: translate(0); }
            5% { text-shadow: -2px 0 #00ff00, 2px 0 #005500; transform: translate(-2px, 1px); }
            10% { text-shadow: 2px 0 #00ff00, -2px 0 #005500; transform: translate(2px, -1px); }
            15% { text-shadow: 0 0 10px #00ff00; transform: translate(0); }
        }

        .loading-bar-container {
            width: 400px; height: 25px; border: 2px solid #00ff00; background-color: #001100;
            padding: 2px; margin-top: 30px; margin-bottom: 20px;
            box-shadow: 0 0 15px rgba(0,255,0,0.4); position: relative; z-index: 60;
        }
        .loading-bar-fill { height: 100%; background-color: #00ff00; width: 0%; }
        .fill-animation { animation: retroLoading 2.8s steps(20) forwards; }
        
        @keyframes retroLoading {
            0% { width: 0%; }
            15% { width: 12%; }
            25% { width: 12%; }
            35% { width: 45%; }
            50% { width: 45%; }
            65% { width: 82%; }
            85% { width: 85%; }
            100% { width: 100%; }
        }
        .transition-content { z-index: 60; position: relative; display: flex; flex-direction: column; align-items: center; }

    </style>
</head>
