        .news-text { font-size: 12px; text-align: justify; font-weight: bold; }
        .msn-btn { background-color: #d4d0c8; border: 3px outset #ffffff; padding: 10px; font-family: "Courier New", Courier, monospace; font-weight: bold; font-size: 14px; cursor: pointer; width: 100%; margin-top: auto; }
        .msn-btn:active { border: 3px inset #ffffff; }
