        .submit-btn { background-color: #000066; color: #ffffff; font-family: "Courier New", Courier, monospace; font-size: 16px; font-weight: bold; padding: 10px 20px; border: 3px outset #ffffff; cursor: pointer; width: 100%; }
        .submit-btn:active { border: 3px inset #ffffff; background-color: #000044; }
        .inkblot-container { width: 180px; height: 120px; background-color: #000; margin: 10px auto; border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; filter: blur(3px) contrast(10); box-shadow: 0 0 10px rgba(0,0,0,0.8); }

        #footer { background-color: #d4d0c8; border-top: 3px ridge #ffffff; padding: 8px 15px; font-size: 10px; color: #000; display: flex; justify-content: space-between; align-items: center; font-weight: bold; }
        .hit-counter { background-color: #000; color: #ff0000; padding: 3px 8px; font-family: 'Courier New', Courier, monospace; border: 2px inset #808080; letter-spacing: 3px; font-size: 12px; }

        /* CHAT MSN */
        #chat-icon { position: fixed; bottom: 20px; right: 20px; background-color: #d4d0c8; border: 2px outset #ffffff; padding: 10px; cursor: pointer; font-family: Tahoma, Arial, sans-serif; font-size: 12px; display: flex; align-items: center; box-shadow: 2px 2px 5px rgba(0,0,0,0.5); z-index: 99; }
        #chat-icon:active { border: 2px inset #ffffff; }
        #chat-icon span { font-weight: bold; color: #000080; margin-left: 5px; }
        #chat-window { position: fixed; bottom: 20px; right: 20px; width: 320px; background-color: #d4d0c8; border: 2px outset #ffffff; box-shadow: 3px 3px 6px rgba(0,0,0,0.6); display: none; flex-direction: column; font-family: Tahoma, Arial, sans-serif; font-size: 12px; z-index: 100; }
        .chat-header { background: linear-gradient(to right, #000080, #1084d0); color: #ffffff; padding: 3px 5px; font-weight: bold; display: flex; justify-content: space-between; align-items: center; }
        .chat-close-btn { background-color: #d4d0c8; border: 2px outset #ffffff; font-family: "Courier New", Courier, monospace; font-weight: bold; font-size: 10px; cursor: pointer; padding: 0 4px; }
