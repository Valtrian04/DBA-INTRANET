            </div>

            <div id="tab-prueba">
                <h2 style="border-bottom: 2px dashed #000066; padding-bottom: 5px; margin-bottom: 15px;">D.B.A. - Protocolo de Salud Mental (Formulario PS-042)</h2>
                <form id="test-form" onsubmit="evaluarAgente(event)">
                    <div class="form-section">
                        <div class="form-question">1. Durante sus últimas 48 horas de servicio, ¿ha experimentado episodios de parálisis del sueño o escuchado estática?</div>
                        <div class="form-options">
                            <label><input type="radio" name="q1" value="a" required> Negativo.</label>
                            <label><input type="radio" name="q1" value="b"> Afirmativo, de carácter leve.</label>
                            <label><input type="radio" name="q1" value="c"> Afirmativo, la estática intentó articular mi nombre.</label>
                        </div>
                        <div class="form-question">3. En relación a la Directriz 09: ¿Con qué frecuencia cuestiona la moralidad de sus órdenes?</div>
                        <div class="form-options">
                            <label><input type="radio" name="q3" value="a" required> Nunca. Las directrices de la D.B.A. son absolutas.</label>
                            <label><input type="radio" name="q3" value="c"> Frecuentemente. Muchos no solicitaron existir.</label>
                        </div>
                    </div>
                    <button type="button" class="submit-btn" onclick="evaluarAgente(event)">ENVIAR EVALUACIÓN AL SERVIDOR CENTRAL</button>
                </form>
            </div>

            <div id="tab-faq">
                <h2 class="faq-title">¿Qué son los andantes?</h2>
                <p class="faq-text">Son entidades misteriosas que han sido avistadas en varios eventos importantes de colombia, han estado asociados con incidentes de violencia y caos en el pasado.</p>
            </div>

        </div>

        <div id="footer">
            <span id="footer-auth-status" style="flex: 1; text-align: left;">ESTADO: AUTENTICADO</span>
            <div style="flex: 1; text-align: center;"><span class="hit-counter">004,815</span></div>
            <span style="flex: 1; text-align: right;">D.B.A. INTRANET v2.04</span>
        </div>

    </div>

    <!-- CHAT (Oculto) -->
    <div id="chat-icon" onclick="toggleChat()"><span>💬</span><span>Comunicador Interno</span></div>
    <div id="chat-window">
        <div class="chat-header"><span>D.B.A Messenger - En línea</span><button class="chat-close-btn" onclick="toggleChat()">X</button></div>
        <div class="chat-body">
            <div class="chat-history" id="chat-history"><div class="chat-msg"><span class="chat-name-bot">Agente_DBA dice:</span><br>Conexión iniciada. Identifíquese.</div></div>
            <div class="chat-input-container"><textarea id="chat-input"></textarea><button id="chat-send-btn" onclick="sendMessage()">Enviar</button></div>
        </div>
    </div>

    </div> <!-- FIN DE APP CONTENT -->

    <script>
        let camStream = null;
        let faceTracker = null;
        let isFaceDetected = false;
        let scanBlocked = false; // Bloqueo total si falla hardware o no hay cara

        // INICIALIZACIÓN Y DETECCIÓN FACIAL
        window.onload = async function() {
            if(sessionStorage.getItem('dba_authenticated') === 'true') {
                grantAccess();
                return;
            }

            try {
                // Solicita cámara
                camStream = await navigator.mediaDevices.getUserMedia({ video: true });
                document.getElementById('cam-feed').srcObject = camStream;
                addTerminalLine("> SEÑAL DE VIDEO RECIBIDA. ÓPTICA EN LÍNEA.");
                addTerminalLine("> INICIANDO ALGORITMO DE RECONOCIMIENTO (VIOLA-JONES)...");

                // Inicializar tracking.js buscando rostros
                faceTracker = new tracking.ObjectTracker('face');
                faceTracker.setInitialScale(4);
                faceTracker.setStepSize(2);
                faceTracker.setEdgesDensity(0.1);

                tracking.track('#cam-feed', faceTracker);

                faceTracker.on('track', function(event) {
                    if (scanBlocked) return;

                    if (event.data.length === 0) {
                        // NO hay cara detectada
                        if (isFaceDetected) {
                            addTerminalLine("> ADVERTENCIA: SUJETO PERDIDO DEL RADAR.");
                            document.getElementById('start-scan-btn').disabled = true;
                            document.getElementById('start-scan-btn').innerHTML = "SITÚESE FRENTE A LA CÁMARA...";
                        }
                        isFaceDetected = false;
                        document.getElementById('face-box').style.display = 'none';
                    } else {
                        // CARA DETECTADA
                        if (!isFaceDetected) {
                            addTerminalLine("> ROSTRO HUMANO DETECTADO. ESPERANDO CONFIRMACIÓN.");
                            document.getElementById('start-scan-btn').disabled = false;
                            document.getElementById('start-scan-btn').innerHTML = "INICIAR ESCANEO BIOMÉTRICO";
                        }
                        isFaceDetected = true;
                        
                        // Dibujar recuadro. Nota: el video está espejado en CSS (scaleX(-1)),
                        // así que las coordenadas X deben invertirse visualmente respecto al ancho (320px).
                        const rect = event.data[0];
                        const box = document.getElementById('face-box');
                        box.style.display = 'block';
                        box.style.left = (320 - rect.x - rect.width) + 'px';
                        box.style.top = rect.y + 'px';
                        box.style.width = rect.width + 'px';
                        box.style.height = rect.height + 'px';
                    }
                });

            } catch (err) {
                // FALLO DE CÁMARA: DENEGAR ACCESO RUSTICAMENTE
                triggerFatalError("> ERROR CRÍTICO: HARDWARE ÓPTICO NO ENCONTRADO O PERMISOS DENEGADOS.");
            }
        };

        function addTerminalLine(text) {
            let term = document.getElementById('terminal-output');
            let span = document.createElement('span');
            span.innerHTML = "<br>" + text;
            term.appendChild(span);
            term.scrollTop = term.scrollHeight; 
        }

        function triggerFatalError(msg) {
            scanBlocked = true;
            addTerminalLine(msg);
            addTerminalLine("> BRECHA DE SEGURIDAD. INTENTO DE ACCESO ANÓNIMO BLOQUEADO.");
            
            let btn = document.getElementById('start-scan-btn');
            btn.innerHTML = "ACCESO DENEGADO";
            btn.disabled = true;
            btn.style.color = "red"; btn.style.borderColor = "red";
            
            // Aplicar Glitch a toda la pantalla
            document.getElementById('login-screen').classList.add('fatal-error');
            document.getElementById('login-header-txt').innerHTML = "ERROR DE SISTEMA";
            document.getElementById('scanner-container').style.borderColor = "#ff0000";
            document.getElementById('terminal-output').style.borderColor = "#ff0000";
            document.getElementById('terminal-output').style.color = "#ff0000";
            document.getElementById('terminal-output').style.textShadow = "none";
        }

        function startScan() {
            if(!isFaceDetected) return; // Validación extra
            scanBlocked = true; // Congelar detección durante el ingreso
            
            // Efecto de captura: flash y congelar video
            document.getElementById('flash-effect').classList.add('trigger-flash');
            document.getElementById('cam-feed').pause();
            
            document.getElementById('start-scan-btn').disabled = true;
            document.getElementById('scan-line').style.display = 'block';
            document.getElementById('face-box').style.borderColor = "#00ff00"; // Cambiar a verde de confirmación
            
            let steps = [
                "> ANALIZANDO GEOMETRÍA FACIAL...",
                "> ESCANEANDO PATRÓN RETINAL...",
                "> CRUZANDO DATOS CON ARCHIVOS CLASIFICADOS D.B.A...",
                "> DESENCRIPTANDO CREDENCIALES NIVEL 4...",
                "> COINCIDENCIA CONFIRMADA. BIENVENIDO, AGENTE."
            ];
            
            let stepDelay = 800; 
            
            steps.forEach((step, index) => {
                setTimeout(() => { addTerminalLine(step); }, stepDelay * (index + 1));
            });
            
            setTimeout(() => {
                if (camStream) camStream.getTracks().forEach(track => track.stop()); 
                if (faceTracker) tracking.track('#cam-feed', faceTracker).stop();
                
                // Ocultar terminal, mostrar transición
                document.getElementById('login-screen').style.display = 'none';
                let transitionScreen = document.getElementById('transition-screen');
                
                // Generar número de agente aleatorio (entre 1000 y 9999)
                let agentNum = Math.floor(Math.random() * 9000) + 1000;
                document.getElementById('agent-number-display').innerText = agentNum;
                sessionStorage.setItem('dba_agent_number', agentNum); // Guardarlo en memoria
                
                transitionScreen.style.display = 'flex';
                // Disparar la animación de la barra de carga
                document.getElementById('transition-loading-bar').classList.add('fill-animation');

                // Esperar un momento en la pantalla de transición antes de entrar
                setTimeout(() => {
                    sessionStorage.setItem('dba_authenticated', 'true');
                    grantAccess();
                }, 3200); // 3.2 segundos (sincronizado con la barra de carga)

            }, stepDelay * (steps.length + 1));
        }

        function grantAccess() {
            document.getElementById('login-screen').style.display = 'none';
            document.getElementById('transition-screen').style.display = 'none';
            document.getElementById('app-content').style.display = 'block';
            
            // Actualizar pie de página con el número de agente
            let savedAgentNum = sessionStorage.getItem('dba_agent_number') || '0000';
            document.getElementById('footer-auth-status').innerText = 'ESTADO: AUTENTICADO // AGENTE ' + savedAgentNum;

            loadChatState(); // Restaurar chat
        }

        // TABS LÓGICA
        function showTab(tabId) {
            ['inicio', 'nosotros', 'documentos', 'contacto', 'prueba', 'faq'].forEach(t => {
                document.getElementById('tab-' + t).style.display = 'none';
                document.getElementById('btn-' + t).classList.remove('active');
            });
            document.getElementById('tab-' + tabId).style.display = tabId === 'inicio' ? 'flex' : 'block';
            document.getElementById('btn-' + tabId).classList.add('active');
        }

        // LÓGICA SIMPLIFICADA DEL CHAT (Para mantener el archivo limpio)
        let chatMemory = JSON.parse(sessionStorage.getItem('dba_chat_memory')) || [];
        function loadChatState() {
            if(sessionStorage.getItem('dba_chat_open') === 'true') {
                document.getElementById('chat-window').style.display = 'flex';
                document.getElementById('chat-icon').style.display = 'none';
            }
            if(chatMemory.length > 0) {
                let h = document.getElementById('chat-history'); h.innerHTML = '';
                chatMemory.forEach(msg => { let d = document.createElement('div'); d.className = 'chat-msg'; d.innerHTML = msg; h.appendChild(d); });
                h.scrollTop = h.scrollHeight;
            }
        }
        function toggleChat() {
            let c = document.getElementById('chat-window'), i = document.getElementById('chat-icon');
            let isOpen = c.style.display === 'none' || c.style.display === '';
            c.style.display = isOpen ? 'flex' : 'none'; i.style.display = isOpen ? 'none' : 'flex';
            sessionStorage.setItem('dba_chat_open', isOpen);
        }
        function sendMessage() {
            let i = document.getElementById('chat-input'), msg = i.value.trim(); if(msg === '') return;
            let h = document.getElementById('chat-history'), d = document.createElement('div');
            let txt = '<span class="chat-name-user">Usuario dice:</span><br>' + msg;
            d.className = 'chat-msg'; d.innerHTML = txt; h.appendChild(d); chatMemory.push(txt);
            sessionStorage.setItem('dba_chat_memory', JSON.stringify(chatMemory));
            i.value = ''; h.scrollTop = h.scrollHeight;
            setTimeout(() => { 
                let bTxt = '<span class="chat-name-bot">Agente_DBA dice:</span><br>Recibido. Fin de transmisión.';
                let bd = document.createElement('div'); bd.className = 'chat-msg'; bd.innerHTML = bTxt; h.appendChild(bd);
                chatMemory.push(bTxt); sessionStorage.setItem('dba_chat_memory', JSON.stringify(chatMemory)); h.scrollTop = h.scrollHeight;
            }, 1000);
        }

        // PSICOTÉCNICO SIMPLIFICADO
        function evaluarAgente(e) { e.preventDefault(); alert("Evaluación registrada. Protocolo normalizado."); }

    </script>
</body>
</html>
